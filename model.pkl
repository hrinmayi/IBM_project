    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "df = pd.read_csv('customer.csv', sep='\\t')\n",
        "\n",
        "print(\"DataFrame shape after correct loading:\", df.shape)\n",
        "display(df.head())\n",
        "\n",
        "df.columns = df.columns.str.strip()\n",
        "df.columns = df.columns.str.replace('\\t', '')\n",
        "print(\"Cleaned DataFrame columns:\", df.columns.tolist())\n",
        "\n",
        "le = LabelEncoder()\n",
        "\n",
        "if 'Target' in df.columns:\n",
        "    if df['Target'].dtype == 'object':\n",
        "        df['Target'] = df['Target'].fillna(df['Target'].mode()[0])\n",
        "\n",
        "    df['Target'] = le.fit_transform(df['Target'])\n",
        "    df['Target'] = df['Target'].fillna(df['Target'].median())\n",
        "else:\n",
        "    print(\"Warning: 'Target' column not found for preprocessing and NaN handling after cleaning.\")\n",
        "\n",
        "for col in df.select_dtypes(include=['object']).columns:\n",
        "    df[col] = le.fit_transform(df[col])\n",
        "\n",
        "print(\"\\nDataFrame head after full preprocessing in _MyGaaFKF1Rm:\")\n",
        "display(df.head())"
      ],
